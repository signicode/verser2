{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "ES2019"
  },
  "files": [],
  "references": [
    {
      "path": "./packages/verser-common"
    },
    {
      "path": "./packages/verser2-guest-js-common"
    },
    {
      "path": "./packages/verser2-host"
    },
    {
      "path": "./packages/verser2-guest-node"
    },
    {
      "path": "./packages/verser2-guest-bun"
    }
  ]
}
