{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "ES2019"
  }
}
